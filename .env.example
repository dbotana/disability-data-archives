# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Dashboard authentication
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme_please

# Email alerts (optional — leave blank to disable)
EMAIL_USER=
EMAIL_PASSWORD=

# Slack webhook (optional — leave blank to disable)
SLACK_WEBHOOK_URL=

# Wayback Machine S3-API keys (optional — higher rate limits when set)
WAYBACK_ACCESS_KEY=
WAYBACK_SECRET_KEY=
